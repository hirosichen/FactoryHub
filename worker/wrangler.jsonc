{
	"name": "factory-hub",
	"main": "src/index.ts",
	"compatibility_date": "2024-12-02",
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"assets": {
		"directory": "../web/dist",
		"binding": "ASSETS"
	},
	"routes": [
		{
			"pattern": "factory.onlymake.ai",
			"custom_domain": true
		}
	]
}
